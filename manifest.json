{
  "manifest_version": 3,
  "name": "xHelper",
  "version": "3.4.0",
  "description": "Your X.com helper: hides promoted posts and adds a download button that always saves the highest-quality MP4.",
  "homepage_url": "https://github.com/asx8678/xvid",
  "minimum_chrome_version": "105",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Download video from this post",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["downloads", "declarativeContent"],
  "host_permissions": ["https://x.com/*", "https://cdn.syndication.twimg.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "world": "ISOLATED",
      "run_at": "document_idle"
    }
  ]
}
