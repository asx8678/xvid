{
  "manifest_version": 3,
  "name": "X Video Downloader",
  "version": "1.0",
  "description": "Download videos from X.com tweets",
  "minimum_chrome_version": "103",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["downloads"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://cdn.syndication.twimg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://x.com/*", "https://twitter.com/*"],
    "js": ["content.js"],
    "world": "ISOLATED",
    "run_at": "document_idle"
  }]
}
