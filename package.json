{
  "name": "xvid",
  "version": "2.4.0",
  "private": true,
  "description": "X Video Downloader - Manifest V3 Chrome extension",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "capture-fixtures": "node scripts/capture-real-fixtures.mjs",
    "manual-qa:smoke": "node tests/manual-qa/extension-smoke.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "vitest": "^2.1.9",
    "jsdom": "^25.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "playwright-core": "^1.51.0",
    "eslint": "^9.23.0",
    "@eslint/js": "^9.23.0",
    "globals": "^15.14.0",
    "prettier": "^3.5.3"
  }
}